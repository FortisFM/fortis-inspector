# Fortis FM Site Inspector - environment variables
# Copy to .env for local dev. On Railway, set these in the Variables panel.

# Required.
PORT=5000
DATA_DIR=./data
NODE_ENV=development

# AI features (Claude). Without this, AI buttons hide and the PDF skips
# the executive summary.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Push notifications (optional). Generate keys with:
#   npx web-push generate-vapid-keys
# Without these, push notification UI is hidden.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fortisfm.com.au
